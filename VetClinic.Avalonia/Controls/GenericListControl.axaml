<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VetClinic.Avalonia.Controls.GenericListControl">

    <StackPanel Margin="10">
        <TextBlock Text="List View" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="ListDataGrid"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  IsReadOnly="True"
                  MaxHeight="500"
                  SelectionMode="Single"
                  CanUserResizeColumns="True"/>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Content="Clear" Command="{Binding ClearCommand}" Padding="20,5"/>
        </StackPanel>
    </StackPanel>
</UserControl>
