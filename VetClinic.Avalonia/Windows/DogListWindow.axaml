<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VetClinic.Avalonia.Controls"
        x:Class="VetClinic.Avalonia.Windows.DogListWindow"
        Title="Dogs" Height="600" Width="800">
    <Grid ColumnDefinitions="*,250">
        <controls:GenericListControl Grid.Column="0" DataContext="{Binding ListVm}"/>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Dog Form" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Name"/>
            <TextBox Text="{Binding CrudVm.Name}" Margin="0,0,0,5"/>
            <TextBlock Text="Breed"/>
            <TextBox Text="{Binding CrudVm.Breed}" Margin="0,0,0,5"/>
            <TextBlock Text="Date of Birth"/>
            <DatePicker SelectedDate="{Binding CrudVm.DateOfBirth}" Margin="0,0,0,5"/>
            <TextBlock Text="Weight (kg)"/>
            <TextBox Text="{Binding CrudVm.WeightKg}" Margin="0,0,0,5"/>
            <TextBlock Text="Chip Number"/>
            <TextBox Text="{Binding CrudVm.ChipNumber}" Margin="0,0,0,5"/>
            <TextBlock Text="Owner ID"/>
            <TextBox Text="{Binding CrudVm.OwnerId}" Margin="0,0,0,10"/>
            <Button Content="Add" Command="{Binding CrudVm.AddCommand}" Padding="5" Margin="0,0,0,5" HorizontalAlignment="Stretch"/>
            <Button Content="Update" Command="{Binding CrudVm.UpdateCommand}" Padding="5" Margin="0,0,0,5" HorizontalAlignment="Stretch"/>
            <Button Content="Delete" Command="{Binding CrudVm.DeleteCommand}" Padding="5" HorizontalAlignment="Stretch"/>
            <TextBlock Text="{Binding CrudVm.ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
