<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VetClinic.Avalonia.Windows.MainWindow"
        Title="VetClinic - Dog Veterinary Management (Avalonia)" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">

        <!-- Header with DB Switcher -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2D3748">
            <TextBlock Text="VetClinic (Avalonia)" FontSize="20" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" Margin="15,10"/>
            <TextBlock Text="Database:" Foreground="White" VerticalAlignment="Center" Margin="30,0,5,0"/>
            <ComboBox x:Name="DbComboBox" Width="120" VerticalAlignment="Center" SelectedIndex="0">
                <ComboBoxItem Content="SQLite"/>
                <ComboBoxItem Content="SQL Server"/>
            </ComboBox>
            <TextBlock Text="{Binding CurrentDatabase, StringFormat='Current: {0}'}"
                       Foreground="LightGreen" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="200,*">

            <!-- Navigation Menu -->
            <StackPanel Grid.Column="0" Background="#EDF2F7">
                <TextBlock Text="Menu" FontWeight="Bold" Margin="10,15,10,5" FontSize="12" Foreground="Gray"/>
                <Button Content="Dogs" Click="OpenDogList_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Owners" Click="OpenOwnerList_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Veterinarians" Click="OpenVetList_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Search Dogs" Click="OpenDogSearch_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Search Owners" Click="OpenOwnerSearch_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Appointments" Click="OpenAppointmentList_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Schedule Appointment" Click="OpenAppointmentScheduler_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Medical Records" Click="OpenMedicalRecord_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Dog History" Click="OpenDogHistory_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Search Appointments" Click="OpenAppointmentSearch_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
                <Button Content="Search Records" Click="OpenMedicalRecordSearch_Click" Margin="5,2" Padding="5" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="Select a section from the menu"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       FontSize="16" Foreground="Gray"/>
        </Grid>
    </Grid>
</Window>
