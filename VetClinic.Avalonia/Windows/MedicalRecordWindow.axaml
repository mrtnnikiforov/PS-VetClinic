<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VetClinic.Avalonia.Controls"
        x:Class="VetClinic.Avalonia.Windows.MedicalRecordWindow"
        Title="Medical Records" Height="600" Width="800">
    <Grid ColumnDefinitions="*,280">
        <controls:GenericListControl Grid.Column="0" DataContext="{Binding ListVm}"/>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Medical Record Form" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Date"/>
            <CalendarDatePicker SelectedDate="{Binding CrudVm.Date}" Margin="0,0,0,5"/>
            <TextBlock Text="Diagnosis"/>
            <TextBox Text="{Binding CrudVm.Diagnosis}" Margin="0,0,0,5"/>
            <TextBlock Text="Treatment"/>
            <TextBox Text="{Binding CrudVm.Treatment}" Height="50" TextWrapping="Wrap" Margin="0,0,0,5"/>
            <TextBlock Text="Medications"/>
            <TextBox Text="{Binding CrudVm.Medications}" Margin="0,0,0,5"/>
            <TextBlock Text="Cost"/>
            <TextBox Text="{Binding CrudVm.Cost}" Margin="0,0,0,5"/>
            <TextBlock Text="Appointment ID"/>
            <TextBox Text="{Binding CrudVm.AppointmentId}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding CrudVm.UsableAppointmentIdsText}" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <Button Content="Add" Command="{Binding CrudVm.AddCommand}" Padding="5" Margin="0,0,0,5" HorizontalAlignment="Stretch"/>
            <Button Content="Update" Command="{Binding CrudVm.UpdateCommand}" Padding="5" Margin="0,0,0,5" HorizontalAlignment="Stretch"/>
            <Button Content="Delete" Command="{Binding CrudVm.DeleteCommand}" Padding="5" HorizontalAlignment="Stretch"/>
            <TextBlock Text="{Binding CrudVm.SuccessMessage}" Foreground="SeaGreen" TextWrapping="Wrap" Margin="0,10,0,0"
                       IsVisible="{Binding CrudVm.HasSuccessMessage}"/>
            <TextBlock Text="{Binding CrudVm.ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap" Margin="0,4,0,0"
                       IsVisible="{Binding CrudVm.HasErrorMessage}"/>
        </StackPanel>
    </Grid>
</Window>
