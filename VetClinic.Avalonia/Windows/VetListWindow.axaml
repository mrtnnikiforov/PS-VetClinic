<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VetClinic.Avalonia.Controls"
        x:Class="VetClinic.Avalonia.Windows.VetListWindow"
        Title="Veterinarians" Height="600" Width="800">
    <Grid ColumnDefinitions="*,250">
        <controls:GenericListControl Grid.Column="0" DataContext="{Binding ListVm}"/>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Veterinarian Form" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="First Name"/>
            <TextBox Text="{Binding CrudVm.FirstName}" Margin="0,0,0,5"/>
            <TextBlock Text="Last Name"/>
            <TextBox Text="{Binding CrudVm.LastName}" Margin="0,0,0,5"/>
            <TextBlock Text="Specialization"/>
            <TextBox Text="{Binding CrudVm.Specialization}" Margin="0,0,0,5"/>
            <TextBlock Text="License Number"/>
            <TextBox Text="{Binding CrudVm.LicenseNumber}" Margin="0,0,0,5"/>
            <TextBlock Text="Phone"/>
            <TextBox Text="{Binding CrudVm.Phone}" Margin="0,0,0,10"/>
            <Button Content="Add" Command="{Binding CrudVm.AddCommand}" Padding="5" Margin="0,0,0,5" HorizontalAlignment="Stretch"/>
            <Button Content="Update" Command="{Binding CrudVm.UpdateCommand}" Padding="5" Margin="0,0,0,5" HorizontalAlignment="Stretch"/>
            <Button Content="Delete" Command="{Binding CrudVm.DeleteCommand}" Padding="5" HorizontalAlignment="Stretch"/>
            <TextBlock Text="{Binding CrudVm.ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
