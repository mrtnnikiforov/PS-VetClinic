<Window x:Class="VetClinic.WPF.Windows.AppointmentSchedulerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Appointment" Height="500" Width="500">
    <StackPanel Margin="20">
        <TextBlock Text="Schedule New Appointment" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Select Dog" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding Dogs}" SelectedItem="{Binding SelectedDog}" DisplayMemberPath="Name" Margin="0,0,0,10"/>

        <TextBlock Text="Select Veterinarian" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding Veterinarians}" SelectedItem="{Binding SelectedVet}" Margin="0,0,0,10">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="{Binding FirstName}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding LastName}"/>
                        <Run Text=" - "/>
                        <Run Text="{Binding Specialization}"/>
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Date" FontWeight="SemiBold"/>
        <DatePicker SelectedDate="{Binding AppointmentDate}" Margin="0,0,0,10"/>

        <TextBlock Text="Reason" FontWeight="SemiBold"/>
        <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <TextBlock Text="Notes" FontWeight="SemiBold"/>
        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="60"
                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

        <Button Content="Schedule Appointment" Command="{Binding ScheduleCommand}" Padding="15,8" HorizontalAlignment="Left"/>

        <TextBlock Text="{Binding StatusMessage}" Foreground="Green" FontWeight="SemiBold" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
