<Window x:Class="VetClinic.WPF.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VetClinic - Dog Veterinary Management" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with DB Switcher -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2D3748" Margin="0">
            <TextBlock Text="VetClinic" FontSize="20" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" Margin="15,10"/>
            <TextBlock Text="Database:" Foreground="White" VerticalAlignment="Center" Margin="30,0,5,0"/>
            <ComboBox x:Name="DbComboBox" Width="120" VerticalAlignment="Center" SelectionChanged="DbComboBox_SelectionChanged">
                <ComboBoxItem Content="SQLite" IsSelected="True"/>
                <ComboBoxItem Content="SQL Server"/>
            </ComboBox>
            <TextBlock Text="{Binding CurrentDatabase, StringFormat='Current: {0}'}"
                       Foreground="LightGreen" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Menu -->
            <StackPanel Grid.Column="0" Background="#EDF2F7" Margin="0">
                <TextBlock Text="Menu" FontWeight="Bold" Margin="10,15,10,5" FontSize="12" Foreground="Gray"/>
                <Button Content="Dogs" Click="OpenDogList_Click" Margin="5,2" Padding="5"/>
                <Button Content="Owners" Click="OpenOwnerList_Click" Margin="5,2" Padding="5"/>
                <Button Content="Veterinarians" Click="OpenVetList_Click" Margin="5,2" Padding="5"/>
                <Button Content="Search Dogs" Click="OpenDogSearch_Click" Margin="5,2" Padding="5"/>
                <Button Content="Search Owners" Click="OpenOwnerSearch_Click" Margin="5,2" Padding="5"/>
                <Button Content="Appointments" Click="OpenAppointmentList_Click" Margin="5,2" Padding="5"/>
                <Button Content="Schedule Appointment" Click="OpenAppointmentScheduler_Click" Margin="5,2" Padding="5"/>
                <Button Content="Medical Records" Click="OpenMedicalRecord_Click" Margin="5,2" Padding="5"/>
                <Button Content="Dog History" Click="OpenDogHistory_Click" Margin="5,2" Padding="5"/>
                <Button Content="Search Appointments" Click="OpenAppointmentSearch_Click" Margin="5,2" Padding="5"/>
                <Button Content="Search Records" Click="OpenMedicalRecordSearch_Click" Margin="5,2" Padding="5"/>
            </StackPanel>

            <!-- Content Area -->
            <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
