<Window x:Class="VetClinic.WPF.Windows.VetListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VetClinic.WPF.Controls"
        Title="Veterinarians" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <controls:GenericListControl Grid.Column="0" DataContext="{Binding ListVm}"/>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Veterinarian Form" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="First Name"/>
            <TextBox Text="{Binding CrudVm.FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="Last Name"/>
            <TextBox Text="{Binding CrudVm.LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="Specialization"/>
            <TextBox Text="{Binding CrudVm.Specialization, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="License Number"/>
            <TextBox Text="{Binding CrudVm.LicenseNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="Phone"/>
            <TextBox Text="{Binding CrudVm.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
            <Button Content="Add" Command="{Binding CrudVm.AddCommand}" Padding="5" Margin="0,0,0,5"/>
            <Button Content="Update" Command="{Binding CrudVm.UpdateCommand}" Padding="5" Margin="0,0,0,5"/>
            <Button Content="Delete" Command="{Binding CrudVm.DeleteCommand}" Padding="5"/>
            <TextBlock Text="{Binding CrudVm.ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
